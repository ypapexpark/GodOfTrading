<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.polymarket.whale.paper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/ghp/Projects/GodOfTrading/.venv-poly/bin/python</string>
        <string>/Users/ghp/Projects/GodOfTrading/polymarket_whale_paper_bot.py</string>
    </array>

    <!-- 5분마다 추적 고래 지갑 9명의 신규 포지션 확인 + 정산. 실주문 없음(paper only). -->
    <key>StartInterval</key>
    <integer>300</integer>

    <key>WorkingDirectory</key>
    <string>/Users/ghp/Projects/GodOfTrading</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/ghp</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/polymarket_whale_paper.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/polymarket_whale_paper_err.log</string>

    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
